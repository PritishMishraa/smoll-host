{
  "name": "@smoll-host/cli",
  "version": "0.1.1",
  "description": "Publish self-contained HTML documents to smoll.host",
  "type": "module",
  "bin": {
    "smoll": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
